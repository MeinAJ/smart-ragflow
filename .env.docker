# Docker 部署专用环境变量
# 将 localhost 替换为 host.docker.internal 以连接宿主机服务

# OpenAI API 配置
OPENAI_API_KEY=sk-125eea6f547f480696d7d71ce18fd047
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# OpenSearch 配置
OPENSEARCH_HOST=host.docker.internal
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=rag_docs

# Redis 配置
REDIS_URL=redis://host.docker.internal:7379
REDIS_DB=0

# MinIO 配置
MINIO_PUBLIC_ENDPOINT=http://host.docker.internal:9000
MINIO_ENDPOINT=host.docker.internal:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=smart-ragflow

# 嵌入模型配置
EMBEDDING_MODEL=bge-m3
EMBEDDING_URL=http://host.docker.internal:11434/api/embeddings
EMBEDDING_TIMEOUT=180

# MMR 参数配置
MMR_LAMBDA=0.5
MMR_TOP_K=5

# tokenizer
TOKENIZER_TYPE=tiktoken
TIKTOKEN_ENCODING=cl100k_base

# 数据库
DATABASE_URL=mysql+pymysql://root:root@host.docker.internal:3306/ragflow?charset=utf8mb4
