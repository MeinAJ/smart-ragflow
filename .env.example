# OpenAI API 配置
# OpenAI API 密钥，用于调用 LLM 服务
OPENAI_API_KEY=your-key-here
# OpenAI API 基础地址
OPENAI_BASE_URL=https://api.openai.com/v1
# 默认使用的模型
OPENAI_MODEL=gpt-3.5-turbo

# OpenSearch 配置
# OpenSearch 主机地址
OPENSEARCH_HOST=localhost
# OpenSearch 服务端口
OPENSEARCH_PORT=9200
# OpenSearch 索引名（用于问答检索）
OPENSEARCH_INDEX=rag_docs
# OpenSearch 用户名（如需要）
OPENSEARCH_USER=
# OpenSearch 密码（如需要）
OPENSEARCH_PASSWORD=

# Redis 配置
# Redis 连接 URL
REDIS_URL=redis://localhost:6379
# Redis 数据库
REDIS_DB=0

# Embedding 缓存配置
# 是否启用缓存
EMBEDDING_CACHE_ENABLED=true
# 缓存过期时间（秒），10天 = 864000
EMBEDDING_CACHE_TTL=864000
# 缓存 key 前缀
EMBEDDING_CACHE_PREFIX=emb:

# MinIO 配置
# MinIO 服务端点地址
MINIO_ENDPOINT=localhost:9000
# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin
# MinIO 密钥
MINIO_SECRET_KEY=minioadmin
# MinIO Bucket 名称（用于存储文档）
MINIO_BUCKET_NAME=smart-ragflow
# 是否使用 HTTPS
MINIO_SECURE=false

# Embedding 配置
# BGE-M3 服务地址
EMBEDDING_URL=http://localhost:8080/embed
# 嵌入模型名称
EMBEDDING_MODEL=BGE-M3
# 向量维度
EMBEDDING_DIM=1024
# Embedding 请求超时（秒）
EMBEDDING_TIMEOUT=30.0

# 分块配置
# 分块大小（token 数）
CHUNK_SIZE=512
# 分块重叠（token 数）
CHUNK_OVERLAP=100
# 分块分隔符（JSON 列表格式）
CHUNK_SEPARATORS=["\n\n", "\n", "。", "；", " ", ""]

# Tokenizer 配置
# tokenizer 类型: tiktoken, huggingface
TOKENIZER_TYPE=tiktoken
# tiktoken encoding: cl100k_base (GPT-4/GPT-3.5), p50k_base (GPT-3)
TIKTOKEN_ENCODING=cl100k_base

# 搜索配置
# 最小分数阈值（0-1范围，归一化后的分数）
SEARCH_MIN_SCORE=0.4
# 文本内容匹配权重
SEARCH_TEXT_BOOST=1.0
# 标题匹配权重
SEARCH_TITLE_BOOST=2.0

# MMR 参数配置
# MMR 多样性权重（0-1，越大多样性越高）
MMR_LAMBDA=0.7
# MMR 返回文档数量
MMR_TOP_K=5

# 解析服务配置
# 支持的文件扩展名（JSON 列表格式）
SUPPORTED_EXTENSIONS=[".pdf", ".docx", ".doc", ".txt", ".md", ".html", ".htm"]
