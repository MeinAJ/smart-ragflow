# OpenAI API 配置
# OpenAI API 密钥，用于调用 LLM 服务
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# OpenSearch 配置
# OpenSearch 主机地址
OPENSEARCH_HOST=localhost
# OpenSearch 服务端口
OPENSEARCH_PORT=9200
# OpenSearch 索引名
OPENSEARCH_INDEX=rag_docs


# Redis 配置
# Redis 连接 URL
REDIS_URL=redis://localhost:7379
REDIS_DB=0

# MinIO 配置
# MinIO 服务端点地址
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ENDPOINT=localhost:9000
# MinIO 访问密钥
MINIO_ACCESS_KEY=minioadmin
# MinIO 密钥
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKECT_NAME=smart-ragflow

# 嵌入模型配置
# 使用的嵌入模型名称
EMBEDDING_MODEL=bge-m3
# BGE-M3 服务地址
EMBEDDING_URL=http://localhost:11434/api/embeddings
EMBEDDING_TIMEOUT=180

# MMR 参数配置
# MMR 多样性权重（0-1，越大多样性越高）
MMR_LAMBDA=0.5
# MMR 返回文档数量
MMR_TOP_K=5

# tokenizer
TOKENIZER_TYPE=tiktoken
TIKTOKEN_ENCODING=cl100k_base

# 数据库
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/ragflow?charset=utf8mb4
